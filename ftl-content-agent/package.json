{
  "name": "ftl-content-agent",
  "version": "1.0.0",
  "private": true,
  "description": "FinTech Law LLC autonomous content agent — orchestration service",
  "type": "module",
  "ftl": {
    "agentId": "content"
  },
  "main": "src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "linkedin:exchange": "node scripts/exchange-linkedin-token.mjs",
    "notion:mcp:test": "node scripts/test-notion-mcp.mjs",
    "sanity:mcp:test": "node scripts/test-sanity-mcp.mjs",
    "slack:ping": "node scripts/slack-ping.mjs",
    "blog:backfill-image": "node scripts/backfill-blog-share-image.mjs",
    "analytics:import": "node scripts/import-analytics.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.16.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sanity/client": "^6.28.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.8.0",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "node-cron": "^4.4.1",
    "oauth-1.0a": "^2.2.6",
    "resend": "^4.5.1",
    "rss-parser": "^3.13.0",
    "satori": "^0.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
