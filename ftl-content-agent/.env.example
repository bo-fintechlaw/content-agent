# Claude API
ANTHROPIC_API_KEY=
# Use a model your Anthropic account can access, e.g. claude-sonnet-4-6 or another allowed model ID
ANTHROPIC_MODEL=

# Sanity CMS (Editor token — read-write)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_SCHEMA_ID=

# LinkedIn API (3-legged OAuth)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Must match LinkedIn app "Authorized redirect URLs" exactly. Use http for local dev (Express has no TLS).
LINKEDIN_REDIRECT_URI=http://localhost:3001/callback/linkedin
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# X (Twitter) API — OAuth 1.0a needs TWO pairs from Keys & tokens (all four values):
#   (1) Consumer Keys → X_API_KEY (Consumer Key) + X_API_SECRET (Consumer Secret)
#   (2) Authentication Tokens → X_ACCESS_TOKEN + X_ACCESS_TOKEN_SECRET (user; for posting as @handle)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional: OAuth 2 / app-only credentials (some v2 endpoints); keep if your portal shows them
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
# X posting is disabled by default. Set to true only when X creds are valid and you want posting enabled.
ENABLE_X_POSTING=false

# Slack app (bot + signing secret for interactivity)
# Channel id: right-click channel in Slack → View channel details → copy (starts with C, or G for private)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Notion MCP (Streamable HTTP — Cursor/agent: point at this /mcp URL; e.g. http://127.0.0.1:3100/mcp)
NOTION_MCP_URL=http://127.0.0.1:3100/mcp
# Optional Bearer token when the MCP HTTP transport requires auth
NOTION_MCP_AUTH_TOKEN=
# Notion API (internal integration) — for @notionhq/client Tier 1 workspace map / schema tools
NOTION_TOKEN=
# Workspace database IDs (for app code / Notion wrappers)
NOTION_DB_CONTENT_CALENDAR=3389323e-019d-816a-ab57-f8ce8f8f2c34
NOTION_DB_REGULATORY_TRACKER=3389323e-019d-81b5-be88-c06b3cae8e12
NOTION_DB_ACTIVITY_LOG=3389323e-019d-81fa-a9d1-ec4ffc69f327

# xAI (Grok) — same family as "Grok" in chat; this key calls https://api.x.ai/ for image generation
# It is NOT X (Twitter): X_API_KEY / X_API_SECRET are for @handle posting only.
# Get a key at https://console.x.ai/
XAI_API_KEY=
# Optional alias (same as XAI_API_KEY) if you prefer a “Grok”-named var:
# GROK_API_KEY=

# Netlify (optional) — build hook after publish
NETLIFY_BUILD_HOOK=

# Content pipeline
# 7 AM ET daily job: only the top ranked topic (after revision queue) is drafted if it meets this score
DAILY_PUBLISH_MIN_RELEVANCE=7
# Optional: require this value as ?token= or X-Content-Agent-Token for GET /api/start-production
PRODUCTION_TRIGGER_SECRET=

# Server
# Public base URL used in Slack review links (e.g. https://your-railway-app.up.railway.app)
APP_BASE_URL=
PORT=3001
NODE_ENV=development
