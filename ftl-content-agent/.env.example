# Claude API
ANTHROPIC_API_KEY=
# Anthropic prompt caching (default on; judge cron every 5 min → 5m TTL)
# ANTHROPIC_PROMPT_CACHE_ENABLED=1
# ANTHROPIC_PROMPT_CACHE_TTL=5m
# Primary model for drafter/judge (Opus 4.7+ omits temperature — handled in anthropic.js)
ANTHROPIC_MODEL=claude-opus-4-8  # pragma: allowlist secret
# Cheaper model used by citation + claim-verification subagents. Routes to a
# separate per-model rate-limit bucket so subagent calls don't compete with
# the main drafter/judge on Opus's TPM quota.
ANTHROPIC_SUBAGENT_MODEL=claude-haiku-4-5-20251001
# Conservative input-tokens-per-minute caps. Hold these below the hard
# Anthropic ceiling for your tier (tier-1 Opus ~30k, Haiku ~50k) so the
# in-process budget guard sleeps before Anthropic 429s you.
ANTHROPIC_TPM_LIMIT=25000
ANTHROPIC_SUBAGENT_TPM_LIMIT=40000

# Sanity CMS (Editor token — read-write)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_SCHEMA_ID=

# LinkedIn API (3-legged OAuth)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Must match LinkedIn app "Authorized redirect URLs" exactly. Use http for local dev (Express has no TLS).
LINKEDIN_REDIRECT_URI=http://localhost:3001/callback/linkedin
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# X (Twitter) API — OAuth 1.0a needs TWO pairs from Keys & tokens (all four values):
#   (1) Consumer Keys → X_API_KEY (Consumer Key) + X_API_SECRET (Consumer Secret)
#   (2) Authentication Tokens → X_ACCESS_TOKEN + X_ACCESS_TOKEN_SECRET (user; for posting as @handle)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional: OAuth 2 / app-only credentials (some v2 endpoints); keep if your portal shows them
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
# X posting is disabled by default. Set to true only when X creds are valid and you want posting enabled.
ENABLE_X_POSTING=false

# Slack app (bot + signing secret for interactivity)
# Channel id: right-click channel in Slack → View channel details → copy (starts with C, or G for private)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# CMO Slack app signing secret (newsletter Approve/Edit/Discard in #bo-review)
SLACK_CMO_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Supabase — content pipeline (topics, drafts, analytics, cron_runs)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase — fleet / ftl-agents (newsletter, subscribers, issue_metrics)
# Project ref: wrxuyabngyaiujgcfexj
SUPABASE_FLEET_URL=
SUPABASE_FLEET_SERVICE_KEY=

# Notion MCP (Streamable HTTP — Cursor/agent: point at this /mcp URL; e.g. http://127.0.0.1:3100/mcp)
NOTION_MCP_URL=http://127.0.0.1:3100/mcp
# Optional Bearer token when the MCP HTTP transport requires auth
NOTION_MCP_AUTH_TOKEN=
# Notion API (internal integration) — for @notionhq/client Tier 1 workspace map / schema tools
NOTION_TOKEN=
# Workspace database IDs (for app code / Notion wrappers)
NOTION_DB_CONTENT_CALENDAR=3389323e-019d-816a-ab57-f8ce8f8f2c34
NOTION_DB_REGULATORY_TRACKER=3389323e-019d-81b5-be88-c06b3cae8e12
NOTION_DB_ACTIVITY_LOG=3389323e-019d-81fa-a9d1-ec4ffc69f327

# xAI (Grok) — same family as "Grok" in chat; this key calls https://api.x.ai/ for image generation
# It is NOT X (Twitter): X_API_KEY / X_API_SECRET are for @handle posting only.
# Get a key at https://console.x.ai/
XAI_API_KEY=
# Optional alias (same as XAI_API_KEY) if you prefer a “Grok”-named var:
# GROK_API_KEY=

# Netlify (optional) — build hook after publish
NETLIFY_BUILD_HOOK=

# Content pipeline
# 7 AM ET daily job: only the top ranked topic (after revision queue) is drafted if it meets this score
DAILY_PUBLISH_MIN_RELEVANCE=7
# Monday ranker backfill target (Wed cron uses 3)
DAILY_PUBLISH_BACKFILL_TARGET=5
# Ranker batch size (Mon cron passes 75; Wed passes 40)
RANK_BATCH_LIMIT=75
# Scanner window (Mon default 168h; Wed cron passes 72h)
SCAN_WINDOW_HOURS=168
SCAN_ITEMS_PER_FEED=35
# Rikka / Charlyn Ho privacy lane (test publish to fintechlaw.ai)
ENABLE_RIKKA_PIPELINE=false
RIKKA_PUBLISH_MODE=ftl_test
# Optional: require this value as ?token= or X-Content-Agent-Token for GET /api/start-production
PRODUCTION_TRIGGER_SECRET=
# Pre-judge quality gate: require at least one verified primary and one verified secondary citation
PREJUDGE_ENFORCE_VERIFIED_CITATIONS=true

# Server
# Public base URL used in Slack review links (e.g. https://your-railway-app.up.railway.app)
APP_BASE_URL=
PORT=3001
NODE_ENV=development

# Newsletter (CMO → content-agent task API)
ENABLE_NEWSLETTER=false
RESEND_API_KEY=
RESEND_FROM=FinTech Law <newsletter@fintechlaw.ai>
RESEND_AUDIENCE_FINANCIAL_SERVICES=
RESEND_AUDIENCE_TECH_AI_LEGAL=
RESEND_WEBHOOK_SECRET=
NEWSLETTER_TOKEN_SECRET=
# Legacy single-audience fallback (optional)
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=FinTech Law <newsletter@fintechlaw.ai>
NEWSLETTER_TEST_EMAIL=
NEWSLETTER_TASK_SECRET=
SLACK_CMO_BO_CHANNEL_ID=C0BB9U7AN0Y
CMO_ASSEMBLE_URL=
